{
    "name": "openhands/hello-script",
    "description": "A modern PHP CLI application that demonstrates PHP development best practices",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "cli",
        "console",
        "example",
        "best-practices"
    ],
    "authors": [
        {
            "name": "OpenHands",
            "email": "openhands@all-hands.dev"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": "^10.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "OpenHands\\HelloScript\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenHands\\HelloScript\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/hello"
    ],
    "scripts": {
        "test": "phpunit",
        "test-coverage": "XDEBUG_MODE=coverage phpunit --coverage-html coverage",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "phpstan": "phpstan analyse",
        "check": [
            "@cs-check",
            "@phpstan",
            "@test"
        ],
        "post-install-cmd": [
            "chmod +x bin/hello"
        ],
        "post-update-cmd": [
            "chmod +x bin/hello"
        ]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit tests",
        "test-coverage": "Run PHPUnit tests with code coverage report",
        "cs-fix": "Fix code style issues",
        "cs-check": "Check code style",
        "phpstan": "Run static analysis",
        "check": "Run all checks"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}